{
  "packageUrlTemplate": "https://github.com/hexaban43/Hex-Studios/releases/download/hex-launcher-v{version}/{packageName}",
  "packageNameTemplate": "Hex-Launcher-win64-{version}.zip",
  "releaseTagTemplate": "hex-launcher-v{version}",
